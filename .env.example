# ---- Required ---------------------------------------------------------------

# Tavily web Search + Extract API key — https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ---- LLM provider (choose ONE) ----------------------------------------------

# Default provider is Anthropic (Claude). Recommended.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin a specific model (defaults to a current Claude Sonnet).
# GROUNDED_MODEL=claude-sonnet-...

# --- Alternative: starter-parity Nebius-hosted open models -------------------
# GROUNDED_PROVIDER=nebius
# NEBIUS_API_KEY=...
# GROUNDED_MODEL=openai/gpt-oss-120b

# ---- Observability (optional) -----------------------------------------------

# Traces export to a local Phoenix UI by default (http://localhost:6006).
# Point this at any OTLP-compatible collector to use a different backend.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Set to 0 to disable tracing entirely.
# GROUNDED_TRACING=1
